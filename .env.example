# Copie para .env (local) e configure os mesmos nomes nas variáveis de
# ambiente do projeto na Vercel (Production + Preview).

# Postgres (Vercel Postgres / Neon / Supabase — string de conexão completa)
DATABASE_URL=

# Segredo para assinar os cookies de sessão (JWT). Gerar com: openssl rand -base64 32
AUTH_SECRET=

# Vercel Blob — criar um Blob Store no dashboard da Vercel e copiar o token
BLOB_READ_WRITE_TOKEN=

# E-mail transacional (Resend) — a integrar depois
RESEND_API_KEY=

# Gateway de pagamento (Stripe ou outro) — a integrar depois
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# URL pública do site (usada em links de e-mail, ex: redefinição de senha)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Credenciais usadas apenas pelo script de seed para criar a primeira conta de admin
ADMIN_SEED_EMAIL=admin@autoresindependentes.com.br
ADMIN_SEED_PASSWORD=
